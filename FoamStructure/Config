# Configuration file for LaserSlab simulation
# AUTO-GENERATED by generateConfig.py - do not edit manually
# Layers: tar1, tar2

REQUIRES Driver
REQUIRES physics/Hydro

USESETUPVARS ThreeT

IF ThreeT
   REQUESTS physics/Diffuse/DiffuseMain/Unsplit

   REQUESTS physics/sourceTerms/Heatexchange/HeatexchangeMain/Spitzer
   REQUESTS physics/materialProperties/Conductivity/ConductivityMain/SpitzerHighZ
ENDIF

# This simulation requires specifying the species via the setup
# line. You must include the species setup variable:
#
# species=cham,tar1,tar2
#

DATAFILES al-imx-003.cn4
DATAFILES he-imx-005.cn4
DATAFILES polystyrene-imx-001.cn4

##########################
#                        #
#   RUNTIME PARAMETERS   #
#                        #
##########################

## Radiation source runtime parameters:
D sim_radSlab Switch to enable radiation temperature BC
PARAMETER sim_radSlab BOOLEAN False

D sim_radSourceType radiation source temperature type (0=constant, 1=Gaussian)
PARAMETER sim_radSourceType  INTEGER 0

D sim_radSourceTMax peak radiation temperature (eV) of the radiation source at domain boundary
PARAMETER sim_radSourceTMax  REAL 500.

D sim_radSourceTMin minimum radiation temperature (eV) of the radiation source at domain boundary
PARAMETER sim_radSourceTMin  REAL 500.

D sim_radSourceStart start time for radiation source
PARAMETER sim_radSourceStart  REAL 0.

D sim_radSourceStop stop time for radiation source
PARAMETER sim_radSourceStop  REAL 1.e99

D sim_radSourcePeak time at which radiation source Gaussian peaks
PARAMETER sim_radSourcePeak  REAL 1.e-9

D sim_radSourceFWHM fwhm of radiation source Gaussian
PARAMETER sim_radSourceFWHM  REAL 1.e-9

D sim_initGeom Use a spherical target if sphere, default to slab
PARAMETER sim_initGeom STRING "slab" ["slab","sphere"]

D sim_targetRadius The radius to use for the target (default for all layers)
PARAMETER sim_targetRadius REAL 0.0050

D sim_vacuumHeight The thickness of the vacuum region in front of the target
PARAMETER sim_vacuumHeight REAL 0.0200

D sim_numLayers Number of target layers
PARAMETER sim_numLayers INTEGER 2

# --- Layer 1: tar1 ---
D sim_rho_1 Initial density for layer 1 (tar1)
PARAMETER sim_rho_1   REAL 2.7

D sim_tele_1 Initial electron temperature for layer 1 (tar1)
PARAMETER sim_tele_1  REAL 290.11375

D sim_tion_1 Initial ion temperature for layer 1 (tar1)
PARAMETER sim_tion_1  REAL 290.11375

D sim_trad_1 Initial radiation temperature for layer 1 (tar1)
PARAMETER sim_trad_1  REAL 290.11375

D sim_height_1 Thickness of layer 1 (tar1) in y-direction
PARAMETER sim_height_1 REAL 0.002

D sim_radius_1 Radial extent of layer 1 (tar1)
PARAMETER sim_radius_1 REAL 0.02

# --- Layer 2: tar2 ---
D sim_rho_2 Initial density for layer 2 (tar2)
PARAMETER sim_rho_2   REAL 1.0

D sim_tele_2 Initial electron temperature for layer 2 (tar2)
PARAMETER sim_tele_2  REAL 290.11375

D sim_tion_2 Initial ion temperature for layer 2 (tar2)
PARAMETER sim_tion_2  REAL 290.11375

D sim_trad_2 Initial radiation temperature for layer 2 (tar2)
PARAMETER sim_trad_2  REAL 290.11375

D sim_height_2 Thickness of layer 2 (tar2) in y-direction
PARAMETER sim_height_2 REAL 0.001

D sim_radius_2 Radial extent of layer 2 (tar2)
PARAMETER sim_radius_2 REAL 0.02

# --- Chamber (background) ---
D sim_rhoCham Initial chamber density
PARAMETER sim_rhoCham   REAL 1e-06

D sim_teleCham Initial chamber electron temperature
PARAMETER sim_teleCham  REAL 290.11375

D sim_tionCham Initial chamber ion temperature
PARAMETER sim_tionCham  REAL 290.11375

D sim_tradCham Initial chamber radiation temperature
PARAMETER sim_tradCham  REAL 290.11375

# --- Custom density map ---
D sim_customDensMap If true, load density/species from external .npz file
PARAMETER sim_customDensMap BOOLEAN False

D sim_densMapFile Path to the .npz density map file
PARAMETER sim_densMapFile STRING "density_map.npz"

D lase_variable saves (density of) the irradiated energy from EnergyDeposition unit
VARIABLE lase TYPE: PER_VOLUME

USESETUPVARS ThscDemo
IF ThscDemo

   REQUIRES diagnostics/ThomsonScattering

   D pwin_variable for debugging: density of Power In from Thomson probe laser
   D pwia_variable for debugging: density of Power In, except where forbidden by critical density
   D pwi1_variable for debugging: density of Power In, attenuated by close-to-critical energy loss
   D pwi2_variable for debugging: density of Power In, attenuated by close-to-critical energy loss along both legs
   D pwde_variable for debugging: density of Power of light from Thomson scattering region detected
   D pwd1_variable for debugging: density of Power of light, attenuated
   D pwd2_variable for debugging: density of Power of light, (2 legs) attenuated

   VARIABLE pwin
   VARIABLE pwia
#   VARIABLE pwi1    # Uncommenting this makes ThomsonScattering MUCH slower!
   VARIABLE pwde
#   VARIABLE pwda
   VARIABLE pwd1
   VARIABLE pwi2
   VARIABLE pwd2

ENDIF
